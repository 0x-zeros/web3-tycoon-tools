{
  "name": "tools",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "TZ": "${localEnv:TZ:America/Los_Angeles}",
      "CLAUDE_CODE_VERSION": "latest",
      "CODEX_VERSION": "latest",
      "GIT_DELTA_VERSION": "0.18.2",
      "ZSH_IN_DOCKER_VERSION": "1.2.0"
    }
  },
  "runArgs": [
    "--security-opt=seccomp=unconfined",
    "--security-opt=apparmor=unconfined",
    "--cpus=12",
    "--memory=24g",
    "--memory-swap=28g",
    "--shm-size=2g"
  ],
  "hostRequirements": {
    "cpus": 8,
    "memory": "16gb",
    "storage": "32gb"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "eamodio.gitlens"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit"
        },
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "bash",
            "icon": "terminal-bash"
          },
          "zsh": {
            "path": "zsh"
          }
        }
      }
    }
  },
  "remoteUser": "node",
  // 端口转发：让 host 浏览器能访问 container 内的本地服务。
  // 1455：ai-gateway 的 OAuth callback 一次性 server（auth login 命令用）
  // 8787：ai-gateway 的 HTTP 网关入口（serve 命令默认端口）
  "forwardPorts": [1455, 8787],
  "portsAttributes": {
    "1455": {
      "label": "AI Gateway OAuth callback",
      "onAutoForward": "silent"
    },
    "8787": {
      "label": "AI Gateway HTTP",
      "onAutoForward": "silent"
    }
  },
  "mounts": [
    "source=claude-code-bashhistory-${devcontainerId},target=/commandhistory,type=volume",
    "source=claude-code-config-${devcontainerId},target=/home/node/.claude,type=volume",
    "source=claude-code-codex-${devcontainerId},target=/home/node/.codex,type=volume"
    // "source=${localEnv:HOME}/.claude,target=/home/node/.claude,type=bind"
  ],
  "containerEnv": {
    "NODE_OPTIONS": "--max-old-space-size=8192",
    "CLAUDE_CONFIG_DIR": "/home/node/.claude",
    "CODEX_HOME": "/home/node/.codex",
    "POWERLEVEL9K_DISABLE_GITSTATUS": "true"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace" //,
  // "postStartCommand": "sudo /usr/local/bin/init-firewall.sh",
  // "waitFor": "postStartCommand"
}
